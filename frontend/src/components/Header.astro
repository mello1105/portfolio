<div class="p-10 flex items-center justify-between">
    <a
        href="/portfolio"
        id="logo-link"
        class="pointer-events-auto z-[101] relative transition-all duration-300"
    >
        <img
            src="/portfolio/Logo.png"
            alt="Matheus Melo"
            class="h-12 md:h-14 w-auto"
        />
    </a>

    <button
        id="menu-toggle"
        class="pointer-events-auto transition-colors duration-300 p-2 z-[101] relative group text-primary hover:opacity-70 cursor-pointer"
    >
        <span class="sr-only">Menu</span>
        <div class="space-y-2 group-data-[open]:space-y-0">
            <span
                class="block w-6 h-0.5 bg-current transition-transform duration-300 group-data-[open]:rotate-45 group-data-[open]:translate-y-2.5"
            ></span>
            <span
                class="block w-6 h-0.5 bg-current transition-opacity duration-300 group-data-[open]:opacity-0"
            ></span>
            <span
                class="block w-6 h-0.5 bg-current transition-transform duration-300 group-data-[open]:-rotate-45"
            ></span>
        </div>
    </button>
</div>

<!-- Full Screen Menu Overlay -->
<div
    id="fullscreen-menu"
    class="fixed inset-0 bg-secondary text-background z-[100] translate-x-full transition-transform duration-500 ease-in-out flex flex-col items-center justify-center pointer-events-auto w-screen h-screen"
>
    <nav class="space-y-8 text-center">
        <a
            href="/portfolio/about"
            class="block text-3xl md:text-5xl font-heading font-medium hover:text-muted transition-colors menu-link"
            >Sobre</a
        >
        <a
            href="/portfolio/experiences"
            class="block text-3xl md:text-5xl font-heading font-medium hover:text-muted transition-colors menu-link"
            >Experiências</a
        >
        <a
            href="/portfolio/#contact"
            class="block text-3xl md:text-5xl font-heading font-medium hover:text-muted transition-colors menu-link"
            >Contato</a
        >
    </nav>
</div>

<script>
    const menuToggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("fullscreen-menu");
    const menuLinks = document.querySelectorAll(".menu-link");
    const logoLink = document.getElementById("logo-link");

    if (menuToggle && menu && logoLink) {
        const toggleMenu = () => {
            const isOpen = menu.classList.contains("translate-x-0");

            if (isOpen) {
                // Close
                menu.classList.remove("translate-x-0");
                menu.classList.add("translate-x-full");
                menuToggle.removeAttribute("data-open");

                // Toggle Color: Back to Dark (Primary)
                menuToggle.classList.remove("text-background");
                menuToggle.classList.add("text-primary");
                logoLink.classList.remove("text-background");
                logoLink.classList.add("text-primary");
                logoLink.classList.remove("invert");

                // Allow scrolling again
                document.body.style.overflow = "";
            } else {
                // Open
                menu.classList.add("translate-x-0");
                menu.classList.remove("translate-x-full");
                menuToggle.setAttribute("data-open", "true");

                // Toggle Color: Light (Background)
                menuToggle.classList.remove("text-primary");
                menuToggle.classList.add("text-background");
                logoLink.classList.remove("text-primary");
                logoLink.classList.add("text-background");
                logoLink.classList.add("invert");

                // Prevent scrolling when menu is open
                document.body.style.overflow = "hidden";
            }
        };

        menuToggle.addEventListener("click", toggleMenu);

        // Close menu on link click
        menuLinks.forEach((link) => {
            link.addEventListener("click", toggleMenu);
        });

        // Close on background click
        menu.addEventListener("click", (e) => {
            if (e.target === menu) {
                toggleMenu();
            }
        });
    }
</script>
