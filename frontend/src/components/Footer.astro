<section
    id="contact"
    class="py-32 px-6 md:px-12 bg-secondary text-background min-h-[70vh] flex items-center justify-center relative"
>
    <div class="max-w-4xl mx-auto text-center">
        <h2
            class="font-heading text-xl md:text-5xl font-bold mb-12 opacity-0 translate-y-8 animate-on-scroll break-all"
        >
            matheusmelomr@gmail.com
        </h2>
    </div>
    <div
        class="absolute bottom-6 right-6 md:bottom-12 md:right-12 flex gap-4 opacity-0 translate-y-8 animate-on-scroll delay-500"
    >
        <a
            href="https://www.linkedin.com/in/matheus-melo-89479b286/"
            target="_blank"
            rel="noopener noreferrer"
            class="p-3 border border-current rounded-full hover:bg-secondary hover:text-black transition-all duration-300 group"
            aria-label="LinkedIn"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="lucide lucide-linkedin"
            >
                <path
                    d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                ></path><rect width="4" height="12" x="2" y="9"></rect><circle
                    cx="4"
                    cy="4"
                    r="2"></circle>
            </svg>
        </a>
        <a
            href="https://wa.me/553195516556"
            target="_blank"
            rel="noopener noreferrer"
            class="p-3 border border-current rounded-full hover:bg-secondary hover:text-black transition-all duration-300 group"
            aria-label="WhatsApp"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="lucide lucide-message-circle"
            >
                <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path>
            </svg>
        </a>
    </div>
</section>
